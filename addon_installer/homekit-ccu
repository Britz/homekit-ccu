#!/bin/sh
ADDON_NAME=homekit-ccu
ADDON_DIR=/usr/local/addons/${ADDON_NAME}
MODULE_DIR=${ADDON_DIR}/node_modules/${ADDON_NAME}
CONFIG_URL=/addons/${ADDON_NAME}/index.html
CONFIG_DIR=/usr/local/etc/config
ADDONCFG_DIR=${CONFIG_DIR}/addons/${ADDON_NAME}
ADDONWWW_DIR=${CONFIG_DIR}/addons/www/${ADDON_NAME}
NPMCACHE_DIR=/tmp/homekit-ccu-cache
RCD_DIR=${CONFIG_DIR}/rc.d
PIDFILE=/var/run/homekit-ccu.pid
VER=0.0.16
NODE_VER=20.18.3
REQUIRED_MAJOR=20
LOGFILE=/var/log/homekit-ccu.log

# ------------------------------------------------------------------
# Helper functions
# ------------------------------------------------------------------

log() {
  local TAG="$1"; shift
  local LOGDATE="$(date '+%m/%d/%Y, %I:%M:%S %p' | sed 's|^0||;s|, 0|, |')"
  echo "[$LOGDATE] [HomeKit-CCU] [$TAG] $*" | tee -a ${LOGFILE}
  logger -t homekit-ccu -p user.info "$*"
}

usage() {
	cmds=$(grep -oE '^([a-z_]+)\(\)' "$0" | sed 's/()//g' | grep -v '^usage$\|^log$\|^detect_\|^check_\|^remove_\|^uninstall_' | tr '\n' '|' | sed 's/|$//')
	echo "Usage: $0 {${cmds}}" >&2
}

# ------------------------------------------------------------------
# Install functions
# ------------------------------------------------------------------

detect_arch() {
  ARCH=$(uname -m)
  case "${ARCH}" in
    aarch64|arm64) echo "arm64" ;;
    x86_64|amd64)  echo "x64" ;;
    *)
      log "install" "ERROR: unsupported architecture: ${ARCH}"
      return 1
      ;;
  esac
}

check_node_version() {
  if ! command -v node >/dev/null 2>&1; then
    log "install" "ERROR: Node.js not found in PATH"
    return 1
  fi

  CURRENT_VERSION=$(node --version 2>/dev/null)
  if [ -z "${CURRENT_VERSION}" ]; then
    log "install" "ERROR: Node.js found but could not determine version"
    return 1
  fi

  CURRENT_MAJOR=$(echo "${CURRENT_VERSION}" | sed 's/^v//' | cut -d. -f1)

  if [ "${CURRENT_MAJOR}" -ge "${REQUIRED_MAJOR}" ] 2>/dev/null; then
    log "install" "Node.js ${CURRENT_VERSION} meets requirement (>=${REQUIRED_MAJOR})"
    return 0
  else
    log "install" "ERROR: Node.js ${CURRENT_VERSION} is too old (need >=${REQUIRED_MAJOR})"
    return 1
  fi
}

install() {
  check_node_version || return 1

  if [ -f ${MODULE_DIR}/index.js ]; then
    log "install" "Existing installation found, removing package first..."
    uninstall_server
  fi

  log "install" "Starting install"
  log "install" "Running on node version: $(node --version)"
  log "install" "NPM is: $(npm --version)"
  log "install" "Program Dir is ${ADDON_DIR}"
  log "install" "Installing HomeKit-CCU."
  
  mkdir -p ${ADDON_DIR}
  chmod 755 ${ADDON_DIR}
  cd ${ADDON_DIR}
  
  mkdir -p ${NPMCACHE_DIR}
  log "install" "Installing Node.JS packages from \"${ADDONCFG_DIR}/etc/homekit-ccu.tgz\"." 
  npm i --cache ${NPMCACHE_DIR} ${ADDONCFG_DIR}/etc/homekit-ccu.tgz >> ${LOGFILE} 2>&1
  rm -rf ${NPMCACHE_DIR}

  log "install" "Installing WebUI files."
  mkdir -p ${ADDONWWW_DIR}/${ADDONNAME}
  cp -af ${MODULE_DIR}/lib/configurationsrv/html/* ${ADDONWWW_DIR}

  log "install" "Installing lighttpd config."
  mkdir -p /etc/config/lighttpd
  cp -af ${MODULE_DIR}/etc/homekit_ccu.conf /etc/config/lighttpd/${ADDON_NAME}.conf
  killall lighttpd 2>/dev/null; sleep 1; lighttpd -f /etc/lighttpd/lighttpd.conf

  log "install" "Creating HomeKit Button."
  node "${MODULE_DIR}/etc/hm_addon.js" homekit-ccu ${MODULE_DIR}/etc/homekit_ccu_addon.cfg >> ${LOGFILE} 2>&1

  log "install" "Adding .nobackup to addon dir."
  touch ${ADDON_DIR}/.nobackup

  # open proxy ports in firewall via TCL library (persists through WebUI saves)
  if [ -f /lib/libfirewall.tcl ]; then
    tclsh - <<EOF
source /lib/libfirewall.tcl
Firewall_loadConfiguration
global Firewall_USER_PORTS
foreach port {9874 49874} {
  if {[lsearch $Firewall_USER_PORTS $port] == -1} {
    lappend Firewall_USER_PORTS $port
  }
}
Firewall_saveConfiguration
Firewall_configureFirewall
EOF
  fi

  log "install" "Installation complete."
}

background_install() {
  LOCKFILE=/var/run/homekit-ccu-install.lock
  exec 9>"$LOCKFILE"
  if ! flock -n 9; then
    log "install" "ERROR: Installation already running, aborting."
    return 1
  fi
  # Remove button during install so the CCU WebUI doesn't show a broken link
  if [ -f ${MODULE_DIR}/etc/hm_addon.js ]; then
    node "${MODULE_DIR}/etc/hm_addon.js" homekit-ccu >> ${LOGFILE} 2>&1
  fi
  log "install" "Running install and start in background"
  (
    install && start
    flock -u 9 >>${LOGFILE} 2>&1
  ) &>/dev/null &
}

# ------------------------------------------------------------------
# Uninstall functions
# ------------------------------------------------------------------

# Uninstall all configurations
uninstall_config() {
  #remove_addon_config
  log "uninstall" "Removing addon config."
  rm -rf ${ADDONCFG_DIR}

  # remove_lighttpd_config
  log "uninstall" "Removing lighttpd config and reloading."
  rm -f /etc/config/lighttpd/${ADDON_NAME}.conf
  killall lighttpd 2>/dev/null; sleep 1; lighttpd -f /etc/lighttpd/lighttpd.conf

  # remove_firewall_ports
  if [ -f /lib/libfirewall.tcl ]; then
    log "uninstall" "Removing firewall ports."
    tclsh - <<EOF
source /lib/libfirewall.tcl
Firewall_loadConfiguration
global Firewall_USER_PORTS
foreach port {9874 49874} {
  set idx [lsearch $Firewall_USER_PORTS $port]
  if {$idx != -1} {
    set Firewall_USER_PORTS [lreplace $Firewall_USER_PORTS $idx $idx]
  }
}
Firewall_saveConfiguration
Firewall_configureFirewall
EOF
  fi

  # remove_monit_config
  if [ -f /usr/local/etc/monit_${ADDON_NAME}.cfg ]; then
    log "uninstall" "Removing monit config."
    rm /usr/local/etc/monit_${ADDON_NAME}.cfg
    /usr/bin/monit reload
  fi
  log "uninstall" "Config removal complete."
}

# Uninstall programm componente keeping the config (for reinstall)
uninstall_server() {
  stop
   # remove WebUI button
  if [ -f ${MODULE_DIR}/etc/hm_addon.js ]; then
    log "uninstall" "Removing WebUI button."
    node "${MODULE_DIR}/etc/hm_addon.js" homekit-ccu >> ${LOGFILE} 2>&1
  fi

  # remove addon directory
  log "uninstall" "Removing addon directory."
  rm -rf ${ADDON_DIR}/

  # remove www_files
  log "uninstall" "Removing www files."
  rm -rf ${ADDONWWW_DIR}

  # remove npm cache if left over from interrupted install
  rm -rf ${NPMCACHE_DIR}

  log "uninstall" "Server removal complete."
}

# Uninstall rc.d script
uninstall_daemon() {
  log "uninstall" "Removing rc.d script."
  rm -f ${RCD_DIR}/${ADDON_NAME}
}

# Full Uninstall
uninstall() {
  log "uninstall" "Removing HomeKit-CCU."
  uninstall_server
  uninstall_config
  uninstall_daemon
  log "uninstall" "Uninstall complete."
}

# ------------------------------------------------------------------
# Daemon functions required by CCU
# ------------------------------------------------------------------

start_debug() {
	log "start" "Starting HomeKit-CCU."
	start-stop-daemon --start --quiet --oknodo --make-pidfile --background --pidfile $PIDFILE --startas "node" -- "$MODULE_DIR/index.js" "-D"
	log "start" "HomeKit-CCU started, log may be found at /tmp/homekit-ccu.log."
}

start() {
	log "start" "Starting HomeKit-CCU."
	start-stop-daemon --start --quiet --oknodo --make-pidfile --background --pidfile $PIDFILE --startas "node" -- "$MODULE_DIR/index.js"
	log "start" "HomeKit-CCU started, log may be found at /tmp/homekit-ccu.log."
}

stop() {
	log "stop" "Stopping HomeKit-CCU."
    start-stop-daemon --stop --quiet --oknodo --retry 5 --pidfile $PIDFILE
    if [ -e $PIDFILE ];then
	  log "stop" "Removing PIDFILE: $PIDFILE."
      rm -f $PIDFILE
    fi
	sleep 2
	pgrep -f 'node.*homekit-ccu' | xargs -r kill -9 2>/dev/null
 	log "stop" "HomeKit-CCU stopped."
}

restart() {
	log "restart" "Performing a HomeKit-CCU start & stop cycle"
	stop
	log "restart" "Wating a short time before restart"
	sleep 10
	start
}

status() {
	LOCKFILE=/var/run/homekit-ccu-install.lock
	if ! flock -n 9 9>"$LOCKFILE" 2>/dev/null; then
		echo "install: running"
	elif [ -f ${MODULE_DIR}/index.js ]; then
		echo "install: complete"
	else
		echo "install: not installed"
	fi
	if [ -f $PIDFILE ] && kill -0 "$(cat $PIDFILE)" 2>/dev/null; then
		echo "server: running (PID $(cat $PIDFILE))"
	else
		echo "server: stopped"
	fi
}

info() {
	LOCKFILE=/var/run/homekit-ccu-install.lock
	INFO_HTML="<center><b>HomeKit-CCU</b><p style='margin-top: 5px;margin-bottom: 5px;'><img src='../addons/homekit-ccu/homekit-ccu-logo.png'></p></center>"

	if ! flock -n 9 9>"$LOCKFILE" 2>/dev/null; then
		INFO_HTML="${INFO_HTML}<br /><b style='color:orange;'>Installation in progress...</b>"
		OPS=""
	elif [ -f $PIDFILE ] && kill -0 "$(cat $PIDFILE)" 2>/dev/null; then
		INFO_HTML="${INFO_HTML}HomeMatic/HomeMatic IP goes Apple Homekit"
		OPS="uninstall stop restart"
	else
		INFO_HTML="${INFO_HTML}<b style='color:red;'>Server stopped</b>"
		OPS="uninstall start"
	fi

	INFO_HTML="${INFO_HTML}<br /><a href='https://github.com/britz/homekit-ccu/'>https://github.com/britz/homekit-ccu/</a>"

	echo "Info: ${INFO_HTML}"
	echo "Name: HomeKit-CCU"
	echo "Version: $VER (Node $NODE_VER)"
	echo "Operations: ${OPS}"
	[ -n "${OPS}" ] && echo "Config-Url: $CONFIG_URL"
	echo "Update: /addons/${ADDON_NAME}/update-check.cgi"
}

# ------------------------------------------------------------------
# Runtime logic
# ------------------------------------------------------------------

CMD="${1:-start}"
if type "$CMD" 2>/dev/null | grep -q 'function'; then
  "$CMD"
else
  usage
  exit 1
fi
