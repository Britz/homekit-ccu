#!/bin/sh

ADDONNAME=homekit-ccu
CONFIG_DIR=/usr/local/etc/config
ADDONCFG_DIR=${CONFIG_DIR}/addons/${ADDONNAME}
RCD_DIR=${CONFIG_DIR}/rc.d

# make sure this addon is only executed on
# supported platforms
if [ "$1" == "HM-RASPBERRYMATIC" ] || [ "$1" == "CCU3" ] ; then

  mount | grep /usr/local 2>&1 >/dev/null
  if [ $? -eq 1 ]; then
    mount /usr/local
  fi

  # create necessary directories
  mkdir -p ${RCD_DIR}
  mkdir -p ${ADDONCFG_DIR}/etc
  
  # copy rc.d script (contains install, uninstall, start, stop, etc.)
  cp -af homekit-ccu ${RCD_DIR}
  
  # copy the npm package so the install function can install from it
  cp -af homekit-ccu.tgz ${ADDONCFG_DIR}/etc/homekit-ccu.tgz
  
  # fix permissions
  chmod 755 ${RCD_DIR}
  chmod +x ${RCD_DIR}/${ADDONNAME}

  # install npm package, lighttpd config, WebUI button
  # (handles stopping and removing old package if present)
  ${RCD_DIR}/${ADDONNAME} install

  # start the service
  ${RCD_DIR}/${ADDONNAME} start
  exit 0
else
  echo "ERROR: unsupported platform '$1'" >&2
  exit 1
fi
